# Node Configuration
PORT=5000
NODE_ENV=development

# Database Settings (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres_password_kora_2026@localhost:5432/cbpa_db

# Cryptographic Keys
# JWT Secret for securing API sessions
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# AES-256 Symmetric Key for encrypting wallet secret keys. MUST be exactly 32 characters.
ENCRYPTION_KEY=your_32_character_encryption_key_

# Stellar Network Configuration
# Use 'testnet' for development and sandbox flows, 'mainnet' for production rails
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Platform Wallet Anchors
ADMIN_PUBLIC_KEY=GBADMIN12345678901234567890123456789012345678901234567890
SEP10_SERVER_KEY=SDSERVERSECRETKEYEXAMPLE123456789012345678901234567890

# Performance Cache Parameters
BALANCE_CACHE_TTL_SECONDS=30

# CORS Allowed Origin
FRONTEND_URL=http://localhost:3000
