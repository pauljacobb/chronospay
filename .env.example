# Port for backend API
PORT=4000

# JWT Secret for session authentication
JWT_SECRET=dev_secret_key_chronospay

# 32-character AES encryption key for wallet private keys
ENCRYPTION_KEY=your_32_character_encryption_key_

# Stellar testnet key configurations (optional for mock mode fallback)
# ADMIN_SECRET_KEY=SDSERVERSECRETKEYEXAMPLE123456789012345678901234567890
# HORIZON_URL=https://horizon-testnet.stellar.org

# PostgreSQL connection string (optional - in-memory mock db will be used if omitted)
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/chronospay
